-- Atualizar label do alvo
task.spawn(function()
    while ScreenGui and ScreenGui.Parent do
        local enemy = findClosestEnemy()
        if enemy then
            TargetLabel.Text = "Alvo: " .. enemy.Name
            TargetLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        else
            TargetLabel.Text = "Alvo: Nenhum"
            TargetLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
        task.wait(0.5)
    end
end)

-- Toggle mode
local function toggleMode()
    enabled = not enabled
    if enabled then
        ToggleButton.Text = "ON"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
        StatusLabel.Text = "🟢 LIGADO"
        StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        print("✅ Modo automático ATIVADO")
        
        -- Loop automático
        task.spawn(function()
            while enabled and ScreenGui and ScreenGui.Parent do
                if not isExecuting then
                    executeCombo()
                end
                task.wait(1)
            end
        end)
    else
        ToggleButton.Text = "OFF"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(100, 0, 0)
        StatusLabel.Text = "🔴 DESLIGADO"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        print("❌ Modo automático DESATIVADO")
    end
end

-- Cliques
ToggleButton.MouseButton1Click:Connect(toggleMode)
ExecuteButton.MouseButton1Click:Connect(function()
    if not enabled then
        executeCombo()
    end
end)
CloseBtn.MouseButton1Click:Connect(function()
    enabled = false
    ScreenGui:Destroy()
end)

-- Arrasto
local dragging = false
local dragStart = nil
local startPos = nil

Titulo.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Atalhos
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.F then
        if not enabled then
            executeCombo()
        end
    elseif input.KeyCode == Enum.KeyCode.F5 then
        toggleMode()
    end
end)

print("✅ Backstep Dash Combo CARREGADO!")
print("📌 Tecla F: Executar | F5: Ligar/Desligar")
print("📌 Dash suave de 0.12 segundos")
