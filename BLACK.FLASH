-- DIVERGENT FIST BACKSTEP DASH (CORRIGIDO - SEM TRAVAMENTO)
local Player = game:GetService("Players").LocalPlayer
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

-- ============================================
-- CONFIGURAÇÕES
-- ============================================
local enabled = false
local isExecuting = false
local backstepDelay = 0.35

-- ============================================
-- FUNÇÃO PARA EXECUTAR O REMOTE
-- ============================================
local function executeDivergentFist()
    pcall(function()
        local character = Player.Character
        if not character then return end
        
        local moveset = character:FindFirstChild("Moveset")
        if not moveset then return end
        
        local divergentFist = moveset:FindFirstChild("Divergent Fist")
        if not divergentFist then return end
        
        local remote = game:GetService("ReplicatedStorage").Knit.Knit.Services.DivergentFistService.RE.Activated
        remote:FireServer(divergentFist)
        print("✅ Divergent Fist executado!")
    end)
end

-- ============================================
-- FUNÇÃO PARA ENCONTRAR INIMIGO MAIS PRÓXIMO
-- ============================================
local function findClosestEnemy()
    local character = Player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        return nil
    end
    
    local myPos = character.HumanoidRootPart.Position
    local closestDistance = 50
    local closestEnemy = nil
    
    for _, otherPlayer in ipairs(game.Players:GetPlayers()) do
        if otherPlayer ~= Player then
            local otherChar = otherPlayer.Character
            if otherChar and otherChar:FindFirstChild("HumanoidRootPart") and otherChar:FindFirstChild("Humanoid") and otherChar.Humanoid.Health > 0 then
                local distance = (otherChar.HumanoidRootPart.Position - myPos).Magnitude
                if distance < closestDistance then
                    closestDistance = distance
                    closestEnemy = otherChar
                end
            end
        end
    end
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
            local isPlayer = false
            for _, p in ipairs(game.Players:GetPlayers()) do
                if p.Character == obj then
                    isPlayer = true
                    break
                end
            end
            if not isPlayer and obj.Humanoid.Health > 0 then
                local distance = (obj.HumanoidRootPart.Position - myPos).Magnitude
                if distance < closestDistance then
                    closestDistance = distance
                    closestEnemy = obj
                end
            end
        end
    end
    
    return closestEnemy
end

-- ============================================
-- FUNÇÃO PARA DAR DASH (SIMPLES E FUNCIONAL)
-- ============================================
local function dashToPosition(targetPosition, lookPosition)
    local character = Player.Character
    if not character then return false end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return false end
    
    -- Salvar velocidade original
    local originalSpeed = humanoid.WalkSpeed
    
    -- Parar movimento
    humanoid.WalkSpeed = 0
    
    -- Calcular nova posição e rotação
    local newCFrame = CFrame.new(targetPosition, lookPosition)
    
    -- Criar tween para o dash (bem rápido)
    local tweenInfo = TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)
    local tween = TweenService:Create(rootPart, tweenInfo, {CFrame = newCFrame})
    
    -- Executar
    tween:Play()
    tween.Completed:Wait()
    
    -- Restaurar velocidade
    humanoid.WalkSpeed = originalSpeed
    
    return true
end

-- ============================================
-- FUNÇÃO PARA DASH ATRÁS DO INIMIGO
-- ============================================
local function backstepOnEnemy(enemy)
    if not enemy then return false end
    
    local character = Player.Character
    if not character then return false end
    
    local enemyRoot = enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Torso")
    if not enemyRoot then return false end
    
    -- Calcular posição atrás do inimigo (baseado na orientação dele)
    local enemyCFrame = enemyRoot.CFrame
    local behindPosition = enemyCFrame.Position - enemyCFrame.LookVector * 4.5
    
    -- Ajustar altura para o chão
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {character, enemy}
    local ray = workspace:Raycast(behindPosition + Vector3.new(0, 5, 0), Vector3.new(0, -10, 0), rayParams)
    if ray then
        behindPosition = Vector3.new(behindPosition.X, ray.Position.Y + 2.5, behindPosition.Z)
    end
    
    print("📍 Teleportando para trás de: " .. enemy.Name)
    
    -- Executar o dash
    local success = dashToPosition(behindPosition, enemyCFrame.Position)
    
    if success then
        print("✅ Dash realizado com sucesso!")
    end
    
    return success
end

-- ============================================
-- FUNÇÃO PRINCIPAL
-- ============================================
local function executeCombo()
    if isExecuting then
        print("⏳ Já executando...")
        return
    end
    
    print("========================================")
    print("🚀 Executando combo...")
    isExecuting = true
    
    local enemy = findClosestEnemy()
    
    if enemy then
        print("🎯 Alvo: " .. enemy.Name)
        
        -- Dar dash para trás do inimigo
        local dashed = backstepOnEnemy(enemy)
        
        if dashed then
            task.wait(0.08)
        end
        
        -- Primeiro golpe
        executeDivergentFist()
        
        -- Delay
        task.wait(backstepDelay)
        
        -- Segundo golpe
        executeDivergentFist()
    else
        print("❌ Nenhum inimigo encontrado!")
        executeDivergentFist()
        task.wait(backstepDelay)
        executeDivergentFist()
    end
    
    task.wait(0.1)
    isExecuting = false
    print("✅ Combo finalizado!")
    print("========================================")
end

