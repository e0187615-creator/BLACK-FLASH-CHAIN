-- DIVERGENT FIST BACKSTEP TOGGLE MÓVEL (COM NPC)
local Player = game:GetService("Players").LocalPlayer
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

-- ============================================
-- CONFIGURAÇÕES
-- ============================================
local enabled = false
local isExecuting = false
local backstepDelay = 0.35

-- ============================================
-- FUNÇÃO PARA EXECUTAR O REMOTE
-- ============================================
local function executeDivergentFist()
    pcall(function()
        local character = Player.Character
        if not character then 
            print("❌ Personagem não encontrado!")
            return
        end
        
        local moveset = character:FindFirstChild("Moveset")
        if not moveset then
            print("❌ Moveset não encontrado!")
            return
        end
        
        local divergentFist = moveset:FindFirstChild("Divergent Fist")
        if not divergentFist then
            print("❌ Divergent Fist não encontrado!")
            return
        end
        
        local args = {
            [1] = divergentFist
        }
        
        game:GetService("ReplicatedStorage").Knit.Knit.Services.DivergentFistService.RE.Activated:FireServer(unpack(args))
        print("✅ Divergent Fist executado!")
    end)
end

-- ============================================
-- FUNÇÃO PARA ENCONTRAR INIMIGO MAIS PRÓXIMO (PLAYER OU NPC)
-- ============================================
local function findClosestEnemy()
    local character = Player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        return nil
    end
    
    local myPos = character.HumanoidRootPart.Position
    local closestDistance = 50
    local closestEnemy = nil
    
    -- Procurar players inimigos
    for _, otherPlayer in ipairs(game.Players:GetPlayers()) do
        if otherPlayer ~= Player then
            local otherChar = otherPlayer.Character
            if otherChar and otherChar:FindFirstChild("HumanoidRootPart") and otherChar:FindFirstChild("Humanoid") and otherChar.Humanoid.Health > 0 then
                local distance = (otherChar.HumanoidRootPart.Position - myPos).Magnitude
                if distance < closestDistance then
                    closestDistance = distance
                    closestEnemy = otherChar
                end
            end
        end
    end
    
    -- Procurar NPCs
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
            -- Verificar se não é player
            local isPlayer = false
            for _, p in ipairs(game.Players:GetPlayers()) do
                if p.Character == obj then
                    isPlayer = true
                    break
                end
            end
            if not isPlayer and obj.Humanoid.Health > 0 then
                local distance = (obj.HumanoidRootPart.Position - myPos).Magnitude
                if distance < closestDistance then
                    closestDistance = distance
                    closestEnemy = obj
                end
            end
        end
    end
    
    return closestEnemy
end

-- ============================================
-- FUNÇÃO PARA DAR BACKSTEP (POSICIONAR ATRÁS DO INIMIGO)
-- ============================================
local function doBackstep(target)
    if not target then 
        print("❌ Nenhum alvo para backstep!")
        return false 
    end
    
    local character = Player.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        print("❌ Personagem não encontrado!")
        return false
    end
    
    local targetRoot = target:FindFirstChild("HumanoidRootPart")
    if not targetRoot then 
        print("❌ Alvo sem HumanoidRootPart!")
        return false 
    end
    
    -- Calcular posição atrás do inimigo
    local targetPos = targetRoot.Position
    local myPos = character.HumanoidRootPart.Position
    local direction = (myPos - targetPos).Unit
    local behindPosition = targetPos + direction * 4.5
    
    -- Rotacionar personagem para olhar o inimigo
    local lookAt = CFrame.new(character.HumanoidRootPart.Position, targetPos)
    character.HumanoidRootPart.CFrame = lookAt
    
    -- Teleportar para trás do inimigo (suave)
    local tweenInfo = TweenInfo.new(0.1, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(character.HumanoidRootPart, tweenInfo, {CFrame = CFrame.new(behindPosition, targetPos)})
    tween:Play()
    tween.Completed:Wait()
    
    print("🎯 Backstep executado! Posicionado atrás de: " .. target.Name)
    return true
end

-- ============================================
-- FUNÇÃO PARA EXECUTAR O COMBO COM BACKSTEP
-- ============================================
local function executeComboWithBackstep()
    if isExecuting then
        print("⏳ Aguarde, já está executando...")
        return
    end
    
    isExecuting = true
    
    -- Encontrar inimigo mais próximo
    local enemy = findClosestEnemy()
    
    if enemy then
        print("🎯 Alvo encontrado: " .. enemy.Name)
        
        -- Dar backstep nas costas do inimigo
        local backstepSuccess = doBackstep(enemy)
        
        if backstepSuccess then
            -- Pequeno delay após o backstep
            task.wait(0.05)
            
            -- Primeira execução do Divergent Fist
            executeDivergentFist()
            
            -- Aguardar 0.35 segundos
            task.wait(backstepDelay)
            
            -- Segunda execução (backstep)
            executeDivergentFist()
        else
            print("❌ Falha no backstep, executando sem posicionamento...")
            executeDivergentFist()
            task.wait(backstepDelay)
            executeDivergentFist()
        end
    else
        print("❌ Nenhum inimigo/NPC próximo encontrado!")
        print("⚡ Executando Divergent Fist sem backstep...")
        executeDivergentFist()
        task.wait(backstepDelay)
        executeDivergentFist()
    end
    
    task.wait(0.1)
    isExecuting = false
    
    print("⚡ Combo completo! (Backstep + 2x Divergent Fist)")
end

