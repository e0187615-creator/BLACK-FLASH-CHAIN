-- ============================================
-- ATUALIZAR LABEL DO ALVO
-- ============================================
local function updateTargetLabel()
    if enabled then
        local enemy = findClosestEnemy()
        if enemy then
            TargetLabel.Text = "Alvo: " .. enemy.Name
            TargetLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        else
            TargetLabel.Text = "Alvo: Nenhum"
            TargetLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
    else
        TargetLabel.Text = "Alvo: ---"
        TargetLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
    end
end

-- Loop para atualizar label do alvo
task.spawn(function()
    while ScreenGui and ScreenGui.Parent do
        updateTargetLabel()
        task.wait(0.5)
    end
end)

-- ============================================
-- FUNÇÃO DO TOGGLE
-- ============================================
local function toggleMode()
    enabled = not enabled
    
    if enabled then
        ToggleButton.Text = "ON"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
        StatusLabel.Text = "🟢 LIGADO"
        StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        print("✅ Modo automático ATIVADO - Executará combos em loop")
        
        -- Iniciar loop automático
        task.spawn(function()
            while enabled and ScreenGui and ScreenGui.Parent do
                if not isExecuting then
                    executeComboWithBackstep()
                end
                task.wait(0.8) -- Delay entre combos
            end
        end)
    else
        ToggleButton.Text = "OFF"
        ToggleButton.BackgroundColor3 = Color3.fromRGB(100, 0, 0)
        StatusLabel.Text = "🔴 DESLIGADO"
        StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        print("❌ Modo automático DESATIVADO")
    end
end

-- ============================================
-- EFEITOS HOVER
-- ============================================
local function setupHover(button, normalColor, hoverColor)
    button.MouseEnter:Connect(function()
        button.BackgroundColor3 = hoverColor
    end)
    button.MouseLeave:Connect(function()
        button.BackgroundColor3 = normalColor
    end)
end

setupHover(ToggleButton, ToggleButton.BackgroundColor3, Color3.fromRGB(0, 130, 0))
setupHover(ExecuteButton, Color3.fromRGB(50, 50, 60), Color3.fromRGB(80, 80, 100))
setupHover(CloseBtn, Color3.fromRGB(60, 60, 70), Color3.fromRGB(200, 50, 50))

-- ============================================
-- CLIQUE DOS BOTÕES
-- ============================================
ToggleButton.MouseButton1Click:Connect(toggleMode)

ExecuteButton.MouseButton1Click:Connect(function()
    if not enabled then
        print("🎮 Executando combo manual com backstep...")
        executeComboWithBackstep()
    else
        print("⚠️ Modo automático ligado, desative para executar manualmente")
    end
end)

CloseBtn.MouseButton1Click:Connect(function()
    enabled = false
    ScreenGui:Destroy()
    print("🔒 Interface fechada")
end)

-- ============================================
-- SISTEMA DE ARRASTO
-- ============================================
local dragging = false
local dragStart = nil
local startPos = nil

Titulo.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- ============================================
-- ATALHOS DE TECLA
-- ============================================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.F then
        if not enabled then
            executeComboWithBackstep()
        end
    elseif input.KeyCode == Enum.KeyCode.F5 then
        toggleMode()
    end
end)

